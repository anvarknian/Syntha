{
  "name": "@syntha/sdk",
  "version": "0.1.0",
  "description": "Typed instrumentation SDK for Syntha agent runtimes.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "5.9.3"
  }
}
